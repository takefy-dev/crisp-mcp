# Required: Crisp plugin credentials from https://marketplace.crisp.chat/
CRISP_IDENTIFIER=your_plugin_identifier
CRISP_KEY=your_plugin_secret_key

# Optional: Default website ID (makes website_id optional on all tools)
CRISP_WEBSITE_ID=

# Optional: Transport mode - "stdio" (default) or "http"
MCP_TRANSPORT=stdio

# Optional: HTTP mode settings
PORT=3000
SERVER_URL=http://localhost:3000
